---
export interface GalleryImage {
  thumb: string;
  full: string;
  alt?: string;
}

export interface Props {
  images: GalleryImage[];
  layout?: 'masonry' | 'grid' | 'justified';
  columns?: number;
}

const { images, layout = 'masonry', columns = 3 } = Astro.props;
const galleryId = `gallery-${Math.random().toString(36).slice(2, 7)}`;
---

<div class={`gallery gallery-${layout} gallery-cols-${columns}`} id={galleryId} data-gallery>
  {images.map((img, i) => (
    <figure class="gallery-item" data-index={i}>
      <img
        src={img.thumb}
        alt={img.alt ?? `Photo ${i + 1}`}
        loading="lazy"
        decoding="async"
      />
      <figcaption class="gallery-overlay">
        <span class="gallery-zoom">&#x2B;</span>
      </figcaption>
    </figure>
  ))}
</div>

<style>
  .gallery {
    width: 100%;
  }

  /* Masonry layout */
  .gallery-masonry {
    columns: 3;
    column-gap: 6px;
  }

  .gallery-masonry.gallery-cols-2 { columns: 2; }
  .gallery-masonry.gallery-cols-4 { columns: 4; }

  .gallery-masonry .gallery-item {
    break-inside: avoid;
    margin-bottom: 6px;
  }

  /* Grid layout */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }

  .gallery-grid.gallery-cols-2 { grid-template-columns: repeat(2, 1fr); }
  .gallery-grid.gallery-cols-4 { grid-template-columns: repeat(4, 1fr); }

  .gallery-grid .gallery-item { aspect-ratio: 4/3; overflow: hidden; }
  .gallery-grid .gallery-item img { width: 100%; height: 100%; object-fit: cover; }

  /* Justified layout */
  .gallery-justified {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .gallery-justified .gallery-item {
    flex: 1 1 300px;
    max-width: 400px;
    overflow: hidden;
  }

  /* Common item styles */
  .gallery-item {
    position: relative;
    cursor: pointer;
    overflow: hidden;
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.3s ease;
  }

  .gallery-item:hover .gallery-overlay {
    background: rgba(0, 0, 0, 0.35);
  }

  .gallery-zoom {
    color: white;
    font-size: 2rem;
    opacity: 0;
    transform: scale(0.5);
    transition: opacity 0.3s ease, transform 0.3s ease;
    line-height: 1;
  }

  .gallery-item:hover .gallery-zoom {
    opacity: 1;
    transform: scale(1);
  }

  @media (max-width: 768px) {
    .gallery-masonry { columns: 2; }
    .gallery-masonry.gallery-cols-4 { columns: 2; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-grid.gallery-cols-4 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 480px) {
    .gallery-masonry { columns: 1; }
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>

<script define:vars={{ galleryId, images }}>
  const gallery = document.getElementById(galleryId);
  if (gallery) {
    const fullImages = images.map((img) => img.full);
    gallery.querySelectorAll('.gallery-item').forEach((item) => {
      item.addEventListener('click', () => {
        const idx = parseInt(item.getAttribute('data-index') ?? '0');
        if (typeof window.openLightbox === 'function') {
          window.openLightbox(fullImages, idx);
        }
      });
    });
  }
</script>
