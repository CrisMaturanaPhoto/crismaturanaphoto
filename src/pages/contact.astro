---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact – Cristóbal Maturana"
  description="Get in touch with Cristóbal Maturana to book a photo session."
>
  <div class="page-hero">
    <div class="container">
      <p class="page-hero-label">GET IN TOUCH WITH US</p>
      <h1>Ready for a photo session?<br />Get in touch.</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-layout">
        <!-- Contact Form -->
        <div class="contact-form-wrap">
          <p class="section-label">Send a message</p>
          <form class="contact-form" id="contact-form" novalidate>
            <div class="form-row">
              <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" placeholder="Your name" required />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" placeholder="your@email.com" required />
              </div>
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="How can I help you?" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" rows="6" placeholder="Tell me about your project..." required></textarea>
            </div>
            <button type="submit" class="btn btn-accent">Send Message</button>
            <p class="form-note" id="form-note" aria-live="polite"></p>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="contact-info">
          <div class="contact-office">
            <p class="section-label">New York</p>
            <ul>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:contact@example.com">contact@example.com</a>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:+10001112222">+1-000-111-222</a>
              </li>
            </ul>
          </div>

          <div class="contact-office">
            <p class="section-label">Paris</p>
            <ul>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:contact@example.com">contact@example.com</a>
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.61 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.16 6.16l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:+10001113333">+1-000-111-333</a>
              </li>
            </ul>
          </div>

          <div class="contact-social">
            <p class="section-label">Follow Along</p>
            <div class="social-row">
              <a href="https://www.facebook.com/Matufoto/" target="_blank" rel="noopener">Facebook</a>
              <a href="https://www.instagram.com/cristobalmaturanaphoto/" target="_blank" rel="noopener">Instagram</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 5rem;
    align-items: start;
  }

  .contact-form .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .form-group label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .form-group input,
  .form-group textarea {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-white);
    padding: 0.85rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 300;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--color-accent);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #555;
  }

  .form-note {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-accent);
  }

  /* Contact info */
  .contact-office {
    margin-bottom: 2.5rem;
  }

  .contact-office ul {
    list-style: none;
    margin-top: 0.75rem;
  }

  .contact-office li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .contact-office li svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .contact-office a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .contact-office a:hover { color: var(--color-white); }

  .social-row {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .social-row a {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    transition: all 0.2s;
  }

  .social-row a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (max-width: 900px) {
    .contact-layout { grid-template-columns: 1fr; gap: 3rem; }
    .contact-form .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const note = document.getElementById('form-note')!;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    note.textContent = 'Thank you! Your message has been sent.';
    form.reset();
    setTimeout(() => { note.textContent = ''; }, 5000);
  });
</script>
