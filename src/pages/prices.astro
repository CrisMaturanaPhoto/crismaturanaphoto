---
import Layout from '../layouts/Layout.astro';

const plans = [
  {
    tier: 'Basic',
    price: '$1,000',
    features: [
      '10 hours on location',
      '500 images',
      'All images are edited',
      'Album with your best images',
    ],
  },
  {
    tier: 'Advanced',
    price: '$2,000',
    featured: true,
    features: [
      '10 hours on location',
      '500 images',
      'All images are edited',
      'Album with your best images',
    ],
  },
  {
    tier: 'Premium',
    price: '$3,000',
    features: [
      '10 hours on location',
      '500 images',
      'All images are edited',
      'Album with your best images',
    ],
  },
];
---

<Layout
  title="Prices – Cristóbal Maturana"
  description="Photography packages and pricing by Cristóbal Maturana."
>
  <div class="page-hero">
    <div class="container">
      <h1>Prices</h1>
      <p>Choose the package that works for you</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="pricing-grid">
        {plans.map((plan) => (
          <div class={`pricing-card ${plan.featured ? 'featured' : ''}`}>
            {plan.featured && <div class="featured-badge">Most Popular</div>}
            <p class="tier-label">{plan.tier.toUpperCase()}</p>
            <p class="price">{plan.price}</p>
            <ul class="features">
              {plan.features.map((f) => (
                <li>
                  <span class="check">✓</span> {f}
                </li>
              ))}
            </ul>
            <a href="/contact" class={`btn ${plan.featured ? 'btn-accent' : ''}`}>Contact Me</a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .pricing-card {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 2.5rem 2rem;
    text-align: center;
    transition: border-color 0.3s;
  }

  .pricing-card:hover {
    border-color: var(--color-accent);
  }

  .pricing-card.featured {
    border-color: var(--color-accent);
    background: #1e1a14;
    padding-top: 3.5rem;
  }

  .featured-badge {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent);
    color: #111;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.3rem 1rem;
    white-space: nowrap;
  }

  .tier-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .price {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 400;
    color: var(--color-white);
    line-height: 1;
    margin-bottom: 2rem;
  }

  .features {
    list-style: none;
    margin-bottom: 2rem;
    text-align: left;
  }

  .features li {
    padding: 0.6rem 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .check {
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .pricing-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  }
</style>
